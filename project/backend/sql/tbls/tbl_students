CREATE TABLE tbl_students (
    id INT AUTO_INCREMENT PRIMARY KEY,
    full_name VARCHAR(100) NOT NULL,
    date_of_birth DATE,
    gender VARCHAR(20),
    contact_number VARCHAR(20),
    email VARCHAR(100),
    address TEXT,
    guardian_name VARCHAR(100),
    emergency_contact VARCHAR(20),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


ALTER TABLE tbl_students
ADD photo TEXT,
ADD sport_interested_id INT,
ADD approval_status VARCHAR(20) DEFAULT 'pending',
ADD rejection_remarks TEXT,
ADD status VARCHAR(20) DEFAULT 'active',
ADD CONSTRAINT student_name UNIQUE (full_name),
ADD CONSTRAINT student_email UNIQUE (email),
ADD CONSTRAINT student_contact UNIQUE (contact_number);
